import random

symbols = ["RELIANCE", "TCS", "INFY", "HDFCBANK"]

print("=== TICK SIMULATOR STARTED ===")

while True:
    symbol = random.choice(symbols)
    price = round(random.uniform(1000, 3000), 2)
    timestamp = time.time()

    print(f"{symbol} | {price} | {timestamp}")

    time.sleep(1)
