class PortfolioManager:

    def __init__(self):

        self.max_total_positions = 15

    def can_open_trade(
        self,
        open_trade_count
    ):

        return (
            open_trade_count
            < self.max_total_positions
        )

    def portfolio_heat(
        self,
        open_trade_count
    ):

        return round(
            open_trade_count
            / self.max_total_positions,
            2
        )
